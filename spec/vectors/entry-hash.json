{
  "description": "entry_hash canonical form: SHA-256(JCS({draw_id, entries[{uuid, operator_ref?, weight} sorted by uuid]}))",
  "vectors": [
    {
      "draw_id": "11111111-1111-4111-8111-111111111111",
      "entries": [
        {
          "operator_ref": null,
          "uuid": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
          "weight": 1
        }
      ],
      "expected_hash": "d6ab8f4c63c05739f87a3cdb0d9235c09b59f4fca558a1394022e673059087e0",
      "expected_jcs": "{\"draw_id\":\"11111111-1111-4111-8111-111111111111\",\"entries\":[{\"uuid\":\"aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\",\"weight\":1}]}",
      "name": "single entry no ref"
    },
    {
      "draw_id": "11111111-1111-4111-8111-111111111111",
      "entries": [
        {
          "operator_ref": "",
          "uuid": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
          "weight": 1
        }
      ],
      "expected_hash": "d6ab8f4c63c05739f87a3cdb0d9235c09b59f4fca558a1394022e673059087e0",
      "expected_jcs": "{\"draw_id\":\"11111111-1111-4111-8111-111111111111\",\"entries\":[{\"uuid\":\"aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\",\"weight\":1}]}",
      "name": "empty-string ref omitted"
    },
    {
      "draw_id": "11111111-1111-4111-8111-111111111111",
      "entries": [
        {
          "operator_ref": "ticket-002",
          "uuid": "bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb",
          "weight": 2
        },
        {
          "operator_ref": "ticket-001",
          "uuid": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
          "weight": 1
        }
      ],
      "expected_hash": "f594d9eaae2470ad44efebda5da818b0ec1920679c2dc6627eabe2b960b7c6b6",
      "expected_jcs": "{\"draw_id\":\"11111111-1111-4111-8111-111111111111\",\"entries\":[{\"operator_ref\":\"ticket-001\",\"uuid\":\"aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\",\"weight\":1},{\"operator_ref\":\"ticket-002\",\"uuid\":\"bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb\",\"weight\":2}]}",
      "name": "two entries sorted by uuid both with refs"
    },
    {
      "draw_id": "11111111-1111-4111-8111-111111111111",
      "entries": [
        {
          "operator_ref": "hello 🎉 \"w\" \\ é",
          "uuid": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
          "weight": 1
        }
      ],
      "expected_hash": "a58721dda97b42338e7b18dfa4da08d65f6faca85d2586432ff33b75ca50d61d",
      "expected_jcs": "{\"draw_id\":\"11111111-1111-4111-8111-111111111111\",\"entries\":[{\"operator_ref\":\"hello 🎉 \\\"w\\\" \\\\ é\",\"uuid\":\"aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\",\"weight\":1}]}",
      "name": "unicode in ref (emoji + quotes + backslash + accented)"
    },
    {
      "draw_id": "11111111-1111-4111-8111-111111111111",
      "entries": [
        {
          "operator_ref": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "uuid": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
          "weight": 1
        }
      ],
      "expected_hash": "25f34ab5f27f084b461b04c9b40d7bb36d7177cdcafac27c0c982183b29641df",
      "expected_jcs": "{\"draw_id\":\"11111111-1111-4111-8111-111111111111\",\"entries\":[{\"operator_ref\":\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\"uuid\":\"aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\",\"weight\":1}]}",
      "name": "ref at exactly 64 bytes"
    },
    {
      "draw_id": "11111111-1111-4111-8111-111111111111",
      "entries": [
        {
          "operator_ref": null,
          "uuid": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
          "weight": 9007199254740991
        }
      ],
      "expected_hash": "00fd41b5ee2a98cc96d3a44f4c3a9b999965821112504b647a467066198426d9",
      "expected_jcs": "{\"draw_id\":\"11111111-1111-4111-8111-111111111111\",\"entries\":[{\"uuid\":\"aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\",\"weight\":9007199254740991}]}",
      "name": "weight at 2^53-1 boundary"
    },
    {
      "draw_id": "11111111-1111-4111-8111-111111111111",
      "entries": [
        {
          "operator_ref": "same",
          "uuid": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
          "weight": 1
        },
        {
          "operator_ref": "same",
          "uuid": "bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb",
          "weight": 1
        }
      ],
      "expected_hash": "a443899054935e91c150489f02245c5d5d6eb92572dd4a3e3f2b4b71cc625aed",
      "expected_jcs": "{\"draw_id\":\"11111111-1111-4111-8111-111111111111\",\"entries\":[{\"operator_ref\":\"same\",\"uuid\":\"aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\",\"weight\":1},{\"operator_ref\":\"same\",\"uuid\":\"bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb\",\"weight\":1}]}",
      "name": "duplicate operator_refs distinct uuids (no dedup)"
    },
    {
      "draw_id": "22222222-2222-4222-8222-222222222222",
      "entries": [
        {
          "operator_ref": null,
          "uuid": "aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa",
          "weight": 1
        }
      ],
      "expected_hash": "94d00da138fc2ba5200d3b14f413da77834ffc8756eb8ee24f1399ac41438766",
      "expected_jcs": "{\"draw_id\":\"22222222-2222-4222-8222-222222222222\",\"entries\":[{\"uuid\":\"aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\",\"weight\":1}]}",
      "name": "same entries different draw_id"
    }
  ]
}
